# AI Social Media Content Generator - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Option 1: OpenAI (uses gpt-4o-mini for cost-effectiveness)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Option 2: Google Gemini (free tier available)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# If neither key is provided, the app uses smart template-based generation
# Both keys can be set simultaneously; OpenAI takes priority
